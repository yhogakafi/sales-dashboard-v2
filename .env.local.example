# Salin file ini jadi .env.local untuk development di komputer sendiri.
# Di Vercel, isi nilai-nilai ini lewat Project Settings > Environment Variables.

# Password untuk halaman /admin. Wajib diisi -- tanpa ini, login admin selalu ditolak.
ADMIN_PASSWORD=ganti-dengan-password-rahasia

# Token Vercel Blob. Kalau project sudah dihubungkan ke Vercel Blob Storage lewat
# dashboard Vercel, variabel ini otomatis tersedia di Production/Preview -- tidak
# perlu diisi manual di sana. Untuk development lokal, ambil dari:
# Vercel Dashboard > Storage > (pilih Blob store) > .env.local tab
BLOB_READ_WRITE_TOKEN=
